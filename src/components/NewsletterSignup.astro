---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Recibe ideas, herramientas y casos prácticos de IA en tu correo.",
  description = "Suscríbete gratis para recibir contenido útil sobre flujos de trabajo potenciados por IA, workflows y oportunidades concretas para equipos y profesionales."
} = Astro.props;
---

<section class="section-tight">
  <div class="container">
    <div class="card card-pad newsletter-signup">
      <div>
        <p class="eyebrow">Boletín gratuito</p>
        <h2 class="title-md">{title}</h2>
        <p class="body-lg">{description}</p>
      </div>
      <form class="newsletter-form">
        <label>
          Email
          <input type="email" placeholder="nombre@empresa.cl" />
        </label>
        <button class="btn btn-primary" type="button">Suscribirme gratis</button>
      </form>
    </div>
  </div>
</section>

<style>
  .newsletter-signup {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 1.4rem;
    align-items: center;
    border-radius: 28px;
  }

  .newsletter-form {
    display: grid;
    gap: 0.8rem;
  }

  .newsletter-form label {
    display: grid;
    gap: 0.45rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .newsletter-form input {
    font: inherit;
    padding: 0.95rem 1rem;
    border-radius: 16px;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 900px) {
    .newsletter-signup {
      grid-template-columns: 1fr;
    }
  }
</style>
