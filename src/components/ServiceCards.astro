---
import type { ServiceCard } from "../data/site";

interface Props {
  items: ServiceCard[];
}

const { items } = Astro.props;
---

<div class="grid grid-2">
  {items.map((item, index) => (
    <article class:list={["card", "card-pad", "service-card", index === 0 && "service-feature", index === 1 && "service-dark"]}>
      <p class="kicker">{item.audience}</p>
      <h3 class="title-md">{item.title}</h3>
      <p class="body-lg">{item.description}</p>
      <ul class="list-clean list-check">
        {item.bullets.map((bullet) => (
          <li>{bullet}</li>
        ))}
      </ul>
      <a class="service-link" href={item.href}>Ver detalle</a>
    </article>
  ))}
</div>

<style>
  .service-card {
    display: grid;
    gap: 1rem;
    min-height: 100%;
  }

  .service-feature {
    background:
      radial-gradient(circle at top right, rgba(0, 209, 255, 0.16), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(234, 240, 247, 0.96));
  }

  .service-dark {
    background:
      radial-gradient(circle at top right, rgba(0, 209, 255, 0.18), transparent 28%),
      linear-gradient(145deg, var(--color-primary), #16325f);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .service-dark .title-md,
  .service-dark .body-lg,
  .service-dark .kicker,
  .service-dark .service-link,
  .service-dark .list-check li {
    color: white;
  }

  .service-dark .list-check li::before {
    background: white;
    box-shadow: 0 0 0 0.18rem rgba(255, 255, 255, 0.16);
  }

  .service-link {
    font-weight: 800;
    color: var(--color-secondary);
  }
</style>
