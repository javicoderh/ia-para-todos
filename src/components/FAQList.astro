---
interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;
---

<div class="faq-list">
  {items.map((item) => (
    <details class="card faq-item">
      <summary>{item.question}</summary>
      <p class="body-lg">{item.answer}</p>
    </details>
  ))}
</div>

<style>
  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .faq-item {
    padding: 1.1rem 1.25rem;
  }

  .faq-item summary {
    cursor: pointer;
    list-style: none;
    font-weight: 800;
    color: var(--color-primary);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item p {
    margin: 1rem 0 0;
  }
</style>
