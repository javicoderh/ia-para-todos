---
interface Props {
  navigation: { label: string; href: string }[];
  brandName: string;
}

const { navigation, brandName } = Astro.props;
---

<header class="site-header">
  <div class="container header-shell">
    <a href="/home" class="brand-lockup">
      <span class="brand-mark">
        <span></span>
        <span></span>
      </span>
      <span>
        <strong>{brandName}</strong>
        <small>IA práctica para crecer y operar mejor</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Principal">
      {navigation.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="header-cta">
      <a class="btn btn-secondary" href="/precios">Ver precios</a>
      <a class="btn btn-primary" href="/diagnostico">Diagnóstico rápido</a>
    </div>

    <details class="mobile-menu">
      <summary aria-label="Abrir menu">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="mobile-menu-panel">
        <nav class="mobile-nav" aria-label="Menu mobile">
          {navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
        <div class="mobile-menu-actions">
          <a class="btn btn-secondary" href="/precios">Ver precios</a>
          <a class="btn btn-primary" href="/diagnostico">Diagnóstico rápido</a>
        </div>
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 0 0;
    backdrop-filter: blur(12px);
  }

  .header-shell {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1.15rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(11, 31, 58, 0.08);
    box-shadow: 0 16px 34px rgba(11, 31, 58, 0.08);
  }

  .brand-lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    min-width: 0;
  }

  .brand-lockup strong,
  .brand-lockup small {
    display: block;
  }

  .brand-lockup strong {
    color: var(--color-primary);
    font-family: var(--font-display);
    font-size: 1.02rem;
  }

  .brand-lockup small {
    color: var(--color-muted);
    font-size: 0.82rem;
  }

  .brand-mark {
    width: 2.9rem;
    height: 2.9rem;
    display: inline-grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.24rem;
    padding: 0.38rem;
    border-radius: 16px;
    background: linear-gradient(145deg, var(--color-primary), #21468f);
    box-shadow: var(--shadow-soft);
  }

  .brand-mark span {
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.92);
  }

  .brand-mark span:last-child {
    background: linear-gradient(180deg, var(--color-accent), rgba(255, 255, 255, 0.92));
  }

  .desktop-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .desktop-nav a {
    color: var(--color-muted);
    font-weight: 700;
    padding: 0.35rem 0;
    position: relative;
  }

  .desktop-nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.1rem;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-secondary));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 180ms ease;
  }

  .desktop-nav a:hover::after {
    transform: scaleX(1);
  }

  .header-cta {
    display: flex;
    gap: 0.75rem;
  }

  .mobile-menu {
    display: none;
    position: static;
    margin-left: auto;
  }

  .mobile-menu summary {
    list-style: none;
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.22rem;
    border-radius: 16px;
    border: 1px solid rgba(11, 31, 58, 0.1);
    background: rgba(255, 255, 255, 0.86);
    cursor: pointer;
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu summary span {
    width: 1.15rem;
    height: 2px;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .mobile-menu-panel {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(100% + 0.6rem);
    z-index: 90;
    padding: 1rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid rgba(11, 31, 58, 0.08);
    box-shadow: 0 20px 42px rgba(11, 31, 58, 0.12);
    transform-origin: top right;
    transform: translateY(-0.35rem) scaleY(0.92);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      opacity 180ms ease;
  }

  .mobile-menu[open] .mobile-menu-panel {
    transform: translateY(0) scaleY(1);
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu.is-closing .mobile-menu-panel {
    transform: translateY(-0.35rem) scaleY(0.92);
    opacity: 0;
    pointer-events: none;
  }

  .mobile-menu summary span {
    transition:
      transform 180ms ease,
      opacity 180ms ease,
      width 180ms ease;
    transform-origin: center;
  }

  .mobile-menu[open] summary span:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }

  .mobile-menu[open] summary span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu[open] summary span:nth-child(3) {
    transform: translateY(-4px) rotate(-45deg);
  }

  .mobile-menu.is-closing summary span:nth-child(1),
  .mobile-menu.is-closing summary span:nth-child(3) {
    transform: none;
  }

  .mobile-menu.is-closing summary span:nth-child(2) {
    opacity: 1;
  }

  .mobile-nav,
  .mobile-menu-actions {
    display: grid;
    gap: 0.7rem;
  }

  .mobile-nav {
    margin-bottom: 0.9rem;
    justify-items: center;
  }

  .mobile-nav a {
    color: var(--color-primary);
    font-weight: 700;
    text-align: center;
  }

  .mobile-menu-actions {
    position: relative;
    padding-top: 1rem;
    justify-items: center;
  }

  .mobile-menu-actions::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    width: min(100%, 13rem);
    height: 1px;
    transform: translateX(-50%);
    background: linear-gradient(
      90deg,
      rgba(11, 31, 58, 0),
      rgba(11, 31, 58, 0.16) 20%,
      rgba(11, 31, 58, 0.28) 50%,
      rgba(11, 31, 58, 0.16) 80%,
      rgba(11, 31, 58, 0)
    );
  }

  @media (max-width: 1080px) {
    .header-shell {
      border-radius: 28px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .desktop-nav {
      order: 3;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      position: relative;
      padding-top: 0.6rem;
      z-index: 90;
    }

    .header-shell {
      position: relative;
      z-index: 91;
      padding: 0.78rem 0.9rem;
      border-radius: 20px;
      flex-wrap: nowrap;
      justify-content: space-between;
    }

    .brand-lockup small,
    .desktop-nav,
    .header-cta {
      display: none;
    }

    .brand-lockup strong {
      font-size: 0.96rem;
    }

    .brand-mark {
      width: 2.55rem;
      height: 2.55rem;
      border-radius: 14px;
    }

    .mobile-menu {
      display: block;
    }
  }
</style>

<script>
  document.querySelectorAll('.mobile-menu').forEach((menu) => {
    const summary = menu.querySelector('summary');
    if (!summary) return;

    let closeTimer;
    const closeWithAnimation = () => {
      menu.classList.add('is-closing');
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(() => {
        menu.removeAttribute('open');
        menu.classList.remove('is-closing');
      }, 220);
    };

    summary.addEventListener('click', (event) => {
      if (menu.hasAttribute('open') && !menu.classList.contains('is-closing')) {
        event.preventDefault();
        closeWithAnimation();
      }
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (menu.hasAttribute('open')) {
          closeWithAnimation();
        }
      });
    });
  });
</script>
