---
interface Props {
  title?: string;
  description?: string;
  compact?: boolean;
}

const {
  title = "Llévate un recurso útil y abre conversación comercial",
  description = "Recibe una guía breve y accionable para detectar oportunidades de IA, ordenar prioridades y conversar con más claridad sobre el siguiente paso."
} = Astro.props;
---

<section class="section-tight">
  <div class="container">
    <div class="card lead-capture">
      <div>
        <p class="eyebrow">Lead magnet</p>
        <h2 class="title-md">{title}</h2>
        <p class="body-lg">{description}</p>
      </div>

      <form
        class="capture-form"
        action="https://formsubmit.co/justarapperguy@gmail.com"
        method="POST"
        data-validated
        novalidate
      >
        <input type="hidden" name="_subject" value="Nuevo lead magnet desde IA para Todos" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_next" value="" data-next-url="/gracias" />
        <label>
          Nombre
          <input type="text" name="nombre" placeholder="Tu nombre" required />
          <span class="field-error" data-error-for="nombre"></span>
        </label>
        <label>
          Email
          <input type="email" name="email" placeholder="nombre@empresa.cl" required />
          <span class="field-error" data-error-for="email"></span>
        </label>
        <label>
          Teléfono
          <input type="tel" name="telefono" placeholder="+56 9 1234 5678" required />
          <span class="field-error" data-error-for="telefono"></span>
        </label>
        <label>
          Quiero recibir
          <select name="recurso">
            <option>Diagnóstico rápido de IA</option>
            <option>Checklist de adopción</option>
            <option>10 workflows para este mes</option>
          </select>
          <span class="field-error" data-error-for="recurso"></span>
        </label>
        <button class="btn btn-primary" type="submit">Quiero recibirlo</button>
      </form>
    </div>
  </div>
</section>

<style>
  .lead-capture {
    padding: 1.6rem;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
  }

  .capture-form {
    display: grid;
    gap: 0.85rem;
  }

  .capture-form label {
    display: grid;
    gap: 0.4rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .capture-form input,
  .capture-form select,
  .capture-form textarea {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 0.9rem 1rem;
    font: inherit;
    background: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 900px) {
    .lead-capture {
      grid-template-columns: 1fr;
    }
  }
</style>
