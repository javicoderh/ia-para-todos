---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import PricingGrid from "../components/PricingGrid.astro";
import CTASection from "../components/CTASection.astro";
import { newsletterPlans } from "../data/site";
---

<BaseLayout title="Boletines y adopción interna | IA para Todos">
  <PageHero
    eyebrow="Contenido interno"
    title="Mantén vivos los flujos de trabajo potenciados por IA con contenido que el equipo sí quiere leer y usar."
    description="Creamos boletines, mini guías e infografías para mantener el impulso, reforzar aprendizajes y ayudar a que más personas adopten flujos de trabajo potenciados por IA con confianza y frecuencia."
  />

  <section class="section">
    <div class="container grid grid-2">
      <article class="card card-pad">
        <h3 class="title-md">Qué incluye esta línea</h3>
        <ul class="list-clean list-check">
          <li>Curación de novedades según industria, rol o prioridades del equipo.</li>
          <li>Ideas de workflow y ejemplos aplicables al trabajo cotidiano.</li>
          <li>Infografías internas y piezas visuales para enseñar mejor.</li>
          <li>Material para pantallas, onboarding o comunicación de cambio.</li>
        </ul>
      </article>
      <article class="card card-pad">
        <h3 class="title-md">Qué aporta al equipo</h3>
        <p class="body-lg">
          Mantiene visibles los flujos de trabajo potenciados por IA en el día a día, refuerza aprendizajes con ejemplos concretos y ayuda a que más personas incorporen buenas prácticas con continuidad.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <PricingGrid items={newsletterPlans} />
    </div>
  </section>

  <CTASection
    title="Cuando el contenido acompaña bien, los flujos de trabajo potenciados por IA se vuelven cultura."
    description="Una comunicación interna bien diseñada ayuda a que más personas entiendan el valor, prueben nuevas herramientas y adopten flujos de trabajo potenciados por IA con más constancia."
  />
</BaseLayout>
