---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/CTASection.astro";
import { articles } from "../../data/site";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
---

<BaseLayout title={`${article.title} | IA para Todos`} description={article.excerpt}>
  <section class="section">
    <div class="container article-shell">
      <a class="tag" href="/news">Volver a news</a>
      <p class="eyebrow">{article.category}</p>
      <h1 class="title-lg">{article.title}</h1>
      <p class="lead">{article.excerpt}</p>
      <div class="article-info">
        <span>{article.date}</span>
        <span>{article.readTime}</span>
        <span>{article.author}</span>
      </div>
      <div class="article-cover">{article.coverLabel}</div>
      <div class="article-content card card-pad">
        {article.content.map((paragraph: string) => (
          <p class="body-lg">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Si este tema ya aparece en tu equipo, conviene convertirlo en un plan concreto."
    description="Podemos ayudarte a bajar estas ideas a capacitación, diagnóstico, contenido interno o una implementación más específica."
    primaryLabel="Solicitar asesoría gratuita"
    primaryHref="/contacto"
  />
</BaseLayout>

<style>
  .article-shell {
    display: grid;
    gap: 1rem;
    max-width: 54rem;
  }

  .article-info {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    color: var(--color-muted);
    font-weight: 700;
  }

  .article-cover {
    min-height: 16rem;
    display: flex;
    align-items: end;
    padding: 1.5rem;
    border-radius: 28px;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    color: white;
    background:
      linear-gradient(150deg, rgba(11, 31, 58, 0.96), rgba(31, 60, 136, 0.86)),
      radial-gradient(circle at top right, rgba(0, 209, 255, 0.26), transparent 26%);
  }

  .article-content {
    display: grid;
    gap: 0.35rem;
  }
  </style>
