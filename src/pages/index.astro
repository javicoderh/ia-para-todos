---
import BaseLayout from "../layouts/BaseLayout.astro";
import LandingNewsCarousel from "../components/LandingNewsCarousel.astro";
import { articles } from "../data/site";
import brainImage from "../assets/brain.png";
---

<BaseLayout
  title="IA para Todos | Radar práctico de IA"
  description="Explora artículos prácticos, entra al portal editorial y suscríbete al boletín semanal gratuito."
  showFooter={false}
>
  <section class="landing-stage">
    <div class="container landing-shell">
      <div class="landing-top">
        <div class="landing-heading">
          <p class="eyebrow">Boletín semanal gratuito</p>
          <h1 class="title-xl">Actualízate todas las semanas.</h1>
          <p class="lead">
            Conéctate a las noticias que encienden oportunidades, elevan tu productividad y transforman tu intuición en acción.
          </p>
          <div class="hero-brain-art" aria-hidden="true">
            <img src={brainImage.src} alt="" loading="lazy" />
          </div>
        </div>

        <aside class="landing-signup card">
          <div class="landing-signup-copy">
            <p class="eyebrow">Boletín gratuito</p>
            <h2 class="title-md">Suscríbete en menos de 10 segundos.</h2>
            <p class="body-lg">
              Recibe 1 edición semanal con artículos y guías para implementar flujos de trabajo top tier en tu negocio.
            </p>
          </div>

          <form
            class="landing-form"
            action="https://formsubmit.co/justarapperguy@gmail.com"
            method="POST"
            data-validated
            novalidate
          >
            <input type="hidden" name="_subject" value="Nueva suscripción al boletín gratuito desde IA para Todos" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_next" value="" data-next-url="/gracias" />

            <label class="landing-field">
              Nombre
              <input type="text" name="nombre" placeholder="Tu nombre" required />
              <span class="field-error" data-error-for="nombre"></span>
            </label>

            <label class="landing-field">
              Email
              <input type="email" name="email" placeholder="nombre@empresa.cl" required />
              <span class="field-error" data-error-for="email"></span>
            </label>

            <button class="btn btn-primary landing-submit" type="submit">Suscribirme gratis</button>
          </form>

          <div class="landing-signup-proof">
            <article>
              <strong>1 correo por semana</strong>
              <span>💎 La crème de la crème.</span>
            </article>
          </div>
        </aside>
      </div>

      <div class="landing-editorial card-dark">
        <div class="landing-editorial-head">
          <div>
            <p class="eyebrow">Lecturas destacadas</p>
            <h2 class="title-md">Biblioteca de ideas aplicadas</h2>
          </div>
          <a class="btn btn-secondary" href="/news">Explorar artículos</a>
        </div>
        <LandingNewsCarousel items={articles} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .landing-stage {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 2rem 0;
  }

  .landing-shell {
    display: grid;
    gap: 1rem;
  }

  .landing-top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 430px);
    gap: 1rem;
    align-items: stretch;
  }

  .landing-heading {
    display: grid;
    gap: 0.65rem;
    align-content: start;
    min-height: 100%;
    padding: 0.2rem 0.25rem 0 0;
  }

  .landing-heading .title-xl {
    font-size: clamp(2.6rem, 4.4vw, 4.45rem);
    line-height: 1.02;
  }

  .hero-brain-art {
    width: min(100%, 29rem);
    margin-top: 0.15rem;
    border-radius: 28px;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(11, 31, 58, 0.92), rgba(31, 60, 136, 0.88));
    box-shadow: 0 16px 38px rgba(11, 31, 58, 0.12);
  }

  .hero-brain-art img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 8;
    object-fit: cover;
  }

  .landing-editorial {
    padding: 1.25rem;
    border-radius: 30px;
    display: grid;
    gap: 0.9rem;
    min-width: 0;
    overflow: hidden;
  }

  .landing-editorial-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .landing-signup {
    padding: 1.2rem;
    border-radius: 28px;
    display: grid;
    gap: 0.95rem;
    align-content: start;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(236, 242, 248, 0.95)),
      var(--color-surface);
  }

  .landing-signup-copy {
    display: grid;
    gap: 0.65rem;
  }

  .landing-form {
    display: grid;
    gap: 0.65rem;
  }

  .landing-field {
    display: grid;
    gap: 0.45rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .landing-field input {
    font: inherit;
    padding: 1rem 1rem;
    border-radius: 18px;
    border: 1px solid rgba(11, 31, 58, 0.12);
    background: rgba(255, 255, 255, 0.95);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
  }

  .landing-submit {
    width: 100%;
  }

  .landing-signup-proof {
    display: grid;
    gap: 0.55rem;
    padding-top: 0;
  }

  .landing-signup-proof article {
    display: grid;
    gap: 0.2rem;
    padding: 0.8rem 0.95rem;
    border-radius: 20px;
    background: rgba(11, 31, 58, 0.04);
    border: 1px solid rgba(11, 31, 58, 0.06);
  }

  .landing-signup-proof strong {
    color: var(--color-primary);
  }

  .landing-signup-proof span {
    color: var(--color-muted);
    line-height: 1.55;
    font-size: 0.95rem;
  }

  .landing-signup-panel :global(.section-tight) {
    padding: 0;
  }

  @media (max-width: 960px) {
    .landing-stage {
      min-height: auto;
      padding: 1.25rem 0 2rem;
    }

    .landing-top {
      grid-template-columns: 1fr;
    }

    .landing-editorial-head {
      align-items: start;
      flex-direction: column;
    }
  }

  @media (max-width: 720px) {
    .landing-stage {
      padding: 0.4rem 0 1rem;
    }

    .landing-top {
      gap: 0.7rem;
    }

    .landing-heading {
      order: 2;
      gap: 0.45rem;
      padding-right: 0;
    }

    .landing-heading .eyebrow {
      font-size: 0.74rem;
      padding: 0.34rem 0.65rem;
    }

    .landing-heading .title-xl {
      font-size: clamp(1.85rem, 7.8vw, 2.35rem);
      line-height: 1.03;
    }

    .landing-heading .lead {
      font-size: 0.98rem;
      line-height: 1.5;
    }

    .hero-brain-art {
      display: none;
    }

    .landing-signup {
      order: 1;
      padding: 1rem;
      gap: 0.8rem;
    }

    .landing-signup-copy {
      gap: 0.45rem;
    }

    .landing-signup .eyebrow {
      font-size: 0.72rem;
      padding: 0.34rem 0.65rem;
    }

    .landing-signup .title-md {
      font-size: clamp(1.25rem, 5.6vw, 1.55rem);
    }

    .landing-signup .body-lg {
      font-size: 0.94rem;
      line-height: 1.45;
    }

    .landing-form {
      gap: 0.55rem;
    }

    .landing-field {
      gap: 0.35rem;
      font-size: 0.92rem;
    }

    .landing-field input {
      padding: 0.82rem 0.9rem;
      border-radius: 16px;
    }

    .landing-submit {
      padding-block: 0.9rem;
    }

    .landing-signup-proof article {
      padding: 0.68rem 0.82rem;
      border-radius: 16px;
    }

    .landing-signup-proof span {
      font-size: 0.88rem;
      line-height: 1.4;
    }

    .landing-editorial {
      display: none;
    }
  }
</style>
