---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import ServiceCards from "../components/ServiceCards.astro";
import PricingGrid from "../components/PricingGrid.astro";
import ArticleCards from "../components/ArticleCards.astro";
import LeadCapture from "../components/LeadCapture.astro";
import CTASection from "../components/CTASection.astro";
import FAQList from "../components/FAQList.astro";
import TrustBar from "../components/TrustBar.astro";
import {
  articles,
  faqs,
  howItWorks,
  newsletterPlans,
  proofPoints,
  services,
  testimonials,
  trustLogos,
  useCases
} from "../data/site";
---

<BaseLayout>
  <Hero />
  <TrustBar items={trustLogos} />

  <section class="section">
    <div class="container">
      <div class="proof-panel card-dark">
        <div>
          <p class="eyebrow">Prueba de valor</p>
          <h2 class="title-lg">La IA se mueve más rápido cuando todos entienden para qué sirve.</h2>
        </div>
        <div class="grid grid-3 proof-grid">
          {proofPoints.map((item) => (
            <article class="proof-item">
              <h3>{item.value}</h3>
              <p>{item.label}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <SectionIntro
          eyebrow="Oferta principal"
          title="Servicios pensados para convertir interés en avance real."
          description="La oferta está ordenada para responder lo que más preguntan empresas y profesionales: cómo empezar, qué conviene implementar y cuánto sentido tiene invertir hoy."
        />
        <a class="btn btn-secondary" href="/productos">Ver portafolio</a>
      </div>
      <ServiceCards items={services} />
    </div>
  </section>

  <section class="section">
    <div class="container split-band">
      <div class="card card-feature split-copy">
        <p class="eyebrow">Cómo se implementa</p>
        <h2 class="title-lg">De la idea al hábito: así empieza la adopción que sí se nota.</h2>
        <p class="lead">
          Una ruta simple para priorizar quick wins y convertir la IA en un sistema de trabajo que el equipo entiende, prueba y adopta con más facilidad.
        </p>
        <a class="btn btn-primary" href="/diagnostico">Ver diagnóstico</a>
      </div>
      <div class="grid flow-grid">
        {howItWorks.map((item) => (
          <article class="card card-pad flow-item">
            <p class="kicker">{item.step}</p>
            <p class="body-lg">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <SectionIntro
          eyebrow="Resultados por audiencia"
          title="Cada área puede ganar tiempo, foco y velocidad si aplica la IA donde importa."
          description="Mostramos dónde la IA puede ahorrar tiempo, ordenar mejor el trabajo y mejorar resultados según cada contexto."
        />
        <a class="btn btn-secondary" href="/casos-de-uso">Explorar casos</a>
      </div>
      <div class="grid grid-2 usecase-grid">
        {useCases.map((item) => (
          <article class="card card-pad usecase-item">
            <h3 class="title-md">{item.title}</h3>
            <p class="body-lg">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <SectionIntro
          eyebrow="Pricing destacado"
          title="Precios claros para tomar decisiones más rápido."
          description="Mostrar rangos desde el inicio ayuda a ordenar expectativas, ahorrar tiempo comercial y avanzar con prospectos mejor calificados."
        />
        <a class="btn btn-secondary" href="/precios">Ver tabla completa</a>
      </div>
      <PricingGrid items={newsletterPlans} />
    </div>
  </section>

  <LeadCapture
    title="Recibe una guía útil y descubre por dónde conviene empezar."
    description="Elige una guía, checklist o diagnóstico inicial y avanza con ideas más claras para tu equipo, tu operación o tu siguiente capacitación."
  />

  <section class="section">
    <div class="container testimonial-band">
      {testimonials.map((item) => (
        <article class="card card-pad quote-card">
          <p class="quote-mark">“</p>
          <p class="quote-text">{item.quote}</p>
          <div class="quote-meta">
            <strong>{item.author}</strong>
            <span>{item.company}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <SectionIntro
          eyebrow="Media layer"
          title="Contenido útil para entender qué vale la pena implementar."
          description="Publicamos contenido para ayudar a decidir mejor: qué herramientas sirven, qué procesos conviene intervenir y cómo construir una adopción más sólida."
        />
        <a class="btn btn-secondary" href="/news">Ir a news</a>
      </div>
      <ArticleCards items={articles} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Preguntas frecuentes"
        title="Lo que normalmente necesitas saber antes de avanzar."
        description="Aclaramos alcances, formatos, precios y puntos de partida para que tomar la decisión sea más simple."
      />
      <div style="margin-top: 2rem;">
        <FAQList items={faqs} />
      </div>
    </div>
  </section>

  <CTASection
    title="Una buena decisión al inicio puede ahorrarte meses de prueba y error."
    description="Conversemos sobre tu caso, tu equipo o tu idea. Podemos recomendarte si conviene partir con capacitación, un agente interno, contenido de adopción o una solución más liviana."
    primaryLabel="Hablar sobre mi caso"
    primaryHref="/contacto"
    secondaryLabel="Comparar servicios"
    secondaryHref="/productos"
  />
</BaseLayout>

<style>
  .proof-panel {
    padding: 2rem;
    border-radius: 34px;
    display: grid;
    gap: 1.6rem;
  }

  .proof-grid {
    gap: 1rem;
  }

  .proof-item {
    padding: 1.1rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .proof-item h3 {
    margin: 0 0 0.6rem;
    font-size: 1.15rem;
    color: white;
    font-family: var(--font-display);
  }

  .proof-item p {
    margin: 0;
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.7;
  }

  .split-band {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 1.35rem;
    align-items: start;
  }

  .split-copy {
    padding: 1.8rem;
    border-radius: 28px;
    position: sticky;
    top: 6rem;
    display: grid;
    gap: 1rem;
  }

  .flow-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .flow-item {
    min-height: 100%;
  }

  .usecase-grid {
    gap: 1rem;
  }

  .usecase-item:nth-child(1),
  .usecase-item:nth-child(4) {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(234, 240, 247, 0.92));
  }

  .testimonial-band {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .quote-card {
    border-radius: 26px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(244, 247, 250, 0.96));
  }

  .quote-mark {
    margin: 0;
    font-size: 3rem;
    line-height: 1;
    color: var(--color-accent-strong);
    font-family: var(--font-display);
  }

  .quote-text {
    margin: 0;
    color: var(--color-primary);
    font-size: 1.06rem;
    line-height: 1.75;
  }

  .quote-meta {
    display: grid;
    gap: 0.2rem;
  }

  .quote-meta strong {
    color: var(--color-primary);
  }

  .quote-meta span {
    color: var(--color-muted);
  }

  @media (max-width: 960px) {
    .split-band,
    .testimonial-band {
      grid-template-columns: 1fr;
    }

    .split-copy {
      position: static;
    }

    .flow-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
